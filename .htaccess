RewriteEngine On

# Zorg dat de RewriteBase correct is (pas aan als project in subfolder staat)
# RewriteBase /

# Als request een bestaand bestand of map is → laat doorgaan
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Alle andere requests naar index.php
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]