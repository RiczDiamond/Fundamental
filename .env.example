# Mail settings
MAIL_FROM=noreply@example.com
MAIL_NAME=Fundamental CMS
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USER=your-mail-user@example.com
MAIL_PASS=
MAIL_SECURE=tls
MAIL_DEBUG=0

# IMAP settings
IMAP_ENABLED=true
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_FLAGS=/imap/ssl
IMAP_MAILBOX=INBOX
IMAP_USER=your-mail-user@example.com
IMAP_PASS=
IMAP_LOOKBACK_DAYS=14
IMAP_MAX_FETCH=50

# Authentication settings
AUTH_DIFFICULTY=medium
AUTH_LENGTH=12
AUTH_PEPPER_ALGORITHM=sha512
AUTH_PEPPER_VALUE=change-this-to-a-long-random-secret
AUTH_COST=10

# Database settings
DB_HOST=localhost
DB_NAME=fundamental
DB_USER=root
DB_PASS=
DB_PREFIX=
DB_CHARSET=utf8mb4
